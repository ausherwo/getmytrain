# Copy this file to `.env.local` and fill in the real value.
# `.env.local` is git-ignored — never commit real secrets.
#
# When you deploy to Vercel, set the same variable in
#   Vercel project → Settings → Environment Variables
# rather than relying on .env.local in production.

# Rail Data Marketplace — Live Arrival and Departure Boards.
# Get this from raildata.org.uk → Subscriptions → your subscription →
# Specification tab → "API access credentials" → Consumer key.
RDM_API_KEY=your_consumer_key_here
